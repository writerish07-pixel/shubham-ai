# ============================================
# Shubham Motors AI Voice Agent - Configuration
# ============================================

# --- EXOTEL TELEPHONY CONFIGURATION ---
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_ACCOUNT_SID=shubhammotors1
EXOTEL_PHONE_NUMBER=+919513886363
EXOTEL_SUBDOMAIN=api.exotel.com

# --- TWILIO (Optional - for backup) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12173973537

# --- AI SERVICES ---
# Groq API Key (for LLM - get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Deepgram API Key (for STT fallback - get from https://deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Sarvam AI API Key (for TTS/STT - get from https://sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key

# Ngrok (for local development)
NGROK_AUTH_TOKEN=your_ngrok_auth_token

# --- GOOGLE SHEETS (Optional) ---
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_CREDENTIALS_JSON='{"type":"service_account",...}'

# --- BUSINESS CONFIGURATION ---
BUSINESS_NAME=Shubham Motors
BUSINESS_CITY=Jaipur
WEBSITE_URL=https://www.shubhammotors.com

# --- WORKING HOURS (24-hour format) ---
WORKING_HOURS_START=9
WORKING_HOURS_END=19
WORKING_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday,Saturday

# --- SALES TEAM (up to 5) ---
SALESPERSON_1_NAME=Rajesh
SALESPERSON_1_MOBILE=+919999999991
SALESPERSON_2_NAME=Prem
SALESPERSON_2_MOBILE=+919999999992
SALESPERSON_3_NAME=Anil
SALESPERSON_3_MOBILE=+919999999993

# --- CALL SETTINGS ---
MAX_FOLLOWUP_ATTEMPTS=3
DEFAULT_FOLLOWUP_TIME=10:00
DEFAULT_LANGUAGE=hinglish
SILENCE_TIMEOUT_SECONDS=5

# --- SERVER CONFIGURATION ---
PUBLIC_URL=https://your-app-name.onrender.com
PORT=5000

# --- HUMAN AGENT TRANSFER ---
# Primary agent for call transfers (when customer wants to talk to human)
PRIMARY_AGENT_NUMBER=+919999999991
PRIMARY_AGENT_NAME=Rajesh

# Additional agents (optional - for round-robin)
AGENT_1_NUMBER=+919999999991
AGENT_1_NAME=Rajesh
AGENT_2_NUMBER=+919999999992
AGENT_2_NAME=Prem

# Transfer DTMF key - customer presses this during call to transfer to agent
TRANSFER_DTMF_KEY=0
