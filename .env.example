# ============================================================
# SHUBHAM MOTORS — AI VOICE AGENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# EXOTEL (Telephony API)
EXOTEL_API_KEY=your_exotel_api_key_here
EXOTEL_API_TOKEN=your_exotel_api_token_here
EXOTEL_ACCOUNT_SID=your_account_sid
EXOTEL_PHONE_NUMBER=+91XXXXXXXXXX
EXOTEL_SUBDOMAIN=api.exotel.com

# GROQ (ultra-fast LLM inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# DEEPGRAM (speech-to-text fallback)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# SARVAM AI (primary TTS + STT for Indian languages)
SARVAM_API_KEY=your_sarvam_api_key_here

# NGROK (tunneling for webhooks during development)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# GOOGLE SHEETS (optional — not used if JSON storage is enabled)
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON={}

# BUSINESS INFO
BUSINESS_NAME=Shubham Motors
BUSINESS_CITY=Jaipur
WEBSITE_URL=

# WORKING HOURS (24h format, IST)
WORKING_HOURS_START=9
WORKING_HOURS_END=19
WORKING_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday,Saturday

# SALES TEAM (up to 5 salespeople for round-robin assignment)
SALESPERSON_1_NAME=Name1
SALESPERSON_1_MOBILE=+91XXXXXXXXXX
SALESPERSON_2_NAME=Name2
SALESPERSON_2_MOBILE=+91XXXXXXXXXX
# SALESPERSON_3_NAME=
# SALESPERSON_3_MOBILE=
# SALESPERSON_4_NAME=
# SALESPERSON_4_MOBILE=
# SALESPERSON_5_NAME=
# SALESPERSON_5_MOBILE=

# CALL SETTINGS
MAX_FOLLOWUP_ATTEMPTS=3
DEFAULT_FOLLOWUP_TIME=10:00
DEFAULT_LANGUAGE=hinglish
SILENCE_TIMEOUT_SECONDS=5

# PUBLIC URL — update every time you restart ngrok
# Required for Exotel webhooks to reach your server
PUBLIC_URL=http://localhost:5000

# APP
PORT=5000
